package main

import (
	"fmt"
	"net/http"

	"github.com/dfryer1193/mjolnir/router"
	"github.com/dfryer1193/mjolnir/utils/errorx"
	"github.com/dfryer1193/mjolnir/utils/httpx"
	"github.com/rs/zerolog/log"
)

func main() {
	r := router.New()

	// Standard healthcheck (Server is up)
	r.Get("/health", func(w http.ResponseWriter, r *http.Request) {
		httpx.RespondJSON(w, r, http.StatusOK, map[string]string{"status": "ok"})
	})

	// Liveness check (Container should not be restarted)
	r.Get("/live", func(w http.ResponseWriter, r *http.Request) {
		httpx.RespondJSON(w, r, http.StatusOK, map[string]string{"status": "ok"})
	})

	// Readiness check (Container is ready to receive traffic)
	// TODO: Implement actual dependency checks (DB, Redis, etc.) here.
	r.Get("/ready", errorx.ErrorHandler(func(w http.ResponseWriter, r *http.Request) *errorx.ApiError {
		return errorx.NewApiError(fmt.Errorf("readiness check not implemented"), http.StatusServiceUnavailable)
	}))

	port := ":8080"
	log.Info().Msgf("Server starting on %s", port)
	if err := http.ListenAndServe(port, r); err != nil {
		log.Fatal().Err(err).Msg("Server failed to start")
	}
}
